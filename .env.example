# TraceCheck Production Environment Variables
# Copy this file to .env and fill in values

# ===== REQUIRED =====

# Secret key for JWT token signing (min 32 chars, random)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TRACECHECK_SECRET_KEY=change-me-to-random-string

# ===== OPTIONAL =====

# Database URL (default: SQLite)
# DATABASE_URL=sqlite+aiosqlite:///data/tracecheck.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/tracecheck

# CORS allowed origins (comma-separated, default: localhost only)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Rate limiting
# RATE_LIMIT_PER_MINUTE=60

# ===== COPERNICUS (for real satellite mode) =====
# Leave empty for mock/simulation mode

# COPERNICUS_CLIENT_ID=
# COPERNICUS_CLIENT_SECRET=
# Or:
# COPERNICUS_USERNAME=
# COPERNICUS_PASSWORD=

# ===== STRIPE (for billing) =====
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ===== EU TRACES NT (for DDS submission) =====
# TRACES_NT_CLIENT_ID=
# TRACES_NT_CLIENT_SECRET=
# TRACES_NT_ENVIRONMENT=test  # test or production
