# SpikeEO Environment Configuration
# Copy this file to .env and fill in your values.
# All variables use the SPIKEEO_ prefix.

# ── Application ─────────────────────────────────────
SPIKEEO_APP_NAME=SpikeEO
SPIKEEO_APP_ENV=development
SPIKEEO_APP_DEBUG=false
SPIKEEO_APP_SECRET_KEY=change-me-to-a-random-64-char-string
SPIKEEO_APP_HOST=0.0.0.0
SPIKEEO_APP_PORT=8000

# ── Database ─────────────────────────────────────────
SPIKEEO_DATABASE_URL=sqlite+aiosqlite:///./spikeeo.db
# PostgreSQL example:
# SPIKEEO_DATABASE_URL=postgresql+asyncpg://user:pass@localhost/spikeeo

# ── Storage paths ─────────────────────────────────────
SPIKEEO_DATA_DIR=./data
SPIKEEO_MODELS_DIR=./models/weights
SPIKEEO_PRETRAINED_DIR=./pretrained
SPIKEEO_RESULTS_DIR=./data/results

# ── Model defaults ────────────────────────────────────
SPIKEEO_DEFAULT_TASK=classification
SPIKEEO_DEFAULT_NUM_CLASSES=2
SPIKEEO_DEFAULT_NUM_BANDS=10
SPIKEEO_DEFAULT_DEPTH=standard
SPIKEEO_CONFIDENCE_THRESHOLD=0.75
SPIKEEO_MAX_UPLOAD_SIZE_MB=500

# ── API rate limiting ─────────────────────────────────
SPIKEEO_RATE_LIMIT_PER_MINUTE=60
SPIKEEO_RATE_LIMIT_BURST=100

# ── Logging ───────────────────────────────────────────
SPIKEEO_LOG_LEVEL=INFO
SPIKEEO_LOG_FORMAT=text

# ── Copernicus Data Space (for examples/carbon_mrv) ──
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
