# ============================================================
# CarbonSNN Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ----- Application -----
APP_NAME=CarbonSNN
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_HOST=0.0.0.0
APP_PORT=8000

# ----- Database -----
# SQLite (default, no extra config needed)
DATABASE_URL=sqlite+aiosqlite:///./carbonsnn.db
# PostgreSQL (uncomment to switch)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/carbonsnn

# ----- Redis / Celery -----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ----- Copernicus / Sentinel-2 -----
COPERNICUS_CLIENT_ID=your-copernicus-client-id
COPERNICUS_CLIENT_SECRET=your-copernicus-client-secret
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
COPERNICUS_SEARCH_URL=https://catalogue.dataspace.copernicus.eu/odata/v1
COPERNICUS_DOWNLOAD_URL=https://download.dataspace.copernicus.eu/odata/v1

# ----- Storage -----
DATA_DIR=./data
MODELS_DIR=./models/weights
TILES_DIR=./data/tiles
RESULTS_DIR=./data/results
CACHE_DIR=./data/cache

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# ----- Webhook -----
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_RETRY_ATTEMPTS=3

# ----- Model Hyperparameters -----
FOREST_SNN_NUM_STEPS=15
CARBON_SNN_NUM_STEPS=25
CONFIDENCE_THRESHOLD=0.75
MIN_DEFORESTATION_AREA_HA=0.5

# ----- IPCC Carbon Parameters -----
IPCC_TROPICAL_AGB_DENSITY=200.0       # Mg C/ha
IPCC_TEMPERATE_AGB_DENSITY=120.0      # Mg C/ha
IPCC_BOREAL_AGB_DENSITY=80.0          # Mg C/ha
IPCC_ROOT_SHOOT_RATIO=0.26

# ----- Streamlit Dashboard -----
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# ----- Logging -----
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                        # json | text
LOG_FILE=./logs/carbonsnn.log

# ----- Scheduler -----
WEEKLY_SCAN_CRON=0 6 * * 1            # Every Monday at 06:00 UTC
SCHEDULER_TIMEZONE=UTC
